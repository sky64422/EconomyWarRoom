{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EconomyWarRoom",
  "version": "0.1.0",
  "identifier": "com.economywarroom.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Economy War Room",
        "width": 320,
        "height": 640,
        "minWidth": 260,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5Q0YzMTVEQkU0MThFNkIKUldScmprRytYVEhQR1pJWXVyMzlKWVczYW1IM2NSaWpFazRHaks5N3lTeFEyMWhCaW5wbEFqOWQK",
      "endpoints": [
        "https://github.com/sky64422/EconomyWarRoom/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
